# Docker Compose environment (copy to .env and adjust for production)

# Auth
BETTER_AUTH_SECRET=dev-secret-change-me
BETTER_AUTH_URL=http://localhost:5176

# WebRTC / TURN (coturn)
TURN_USER=chat
TURN_PASSWORD=chatpass
TURN_HOST=localhost
TURN_EXTERNAL_IP=127.0.0.1

# Default admin (created on server startup)
ADMIN_EMAIL=admin@chat.local
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=admin

# MinIO object storage (required — all files are stored here)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=chat-uploads
